{
  "name": "copilot-memory",
  "displayName": "Copilot Memory",
  "description": "Persistent local memory for GitHub Copilot Chat across sessions",
  "version": "0.0.1",
  "publisher": "local",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/local/copilot-memory"
  },
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "main": "./out/extension.js",
  "activationEvents": [],
  "contributes": {
    "languageModelTools": [
      {
        "name": "copilot-memory_save",
        "displayName": "Save Memory",
        "description": "Save information to persistent local memory. Use this to remember decisions, solutions, patterns, architecture notes, or anything worth recalling later.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "content": {
              "type": "string",
              "description": "The information to save"
            },
            "scope": {
              "type": "string",
              "enum": ["personal", "project"],
              "description": "personal = your notes across all repos, project = scoped to current repo"
            }
          },
          "required": ["content"]
        },
        "canBeReferencedInPrompt": true
      },
      {
        "name": "copilot-memory_search",
        "displayName": "Search Memory",
        "description": "Search saved memories for relevant context. Searches both personal and project-scoped memories.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "query": {
              "type": "string",
              "description": "Search query to find relevant memories"
            }
          },
          "required": ["query"]
        },
        "canBeReferencedInPrompt": true
      },
      {
        "name": "copilot-memory_list",
        "displayName": "List Memories",
        "description": "List all saved memories, optionally filtered by scope.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "scope": {
              "type": "string",
              "enum": ["personal", "project"],
              "description": "Filter by scope, or omit to list all"
            }
          }
        },
        "canBeReferencedInPrompt": true
      },
      {
        "name": "copilot-memory_delete",
        "displayName": "Delete Memory",
        "description": "Delete a specific memory by its ID.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "description": "The UUID of the memory to delete"
            }
          },
          "required": ["id"]
        },
        "canBeReferencedInPrompt": true
      }
    ],
    "commands": [
      {
        "command": "copilot-memory.saveSelection",
        "title": "Copilot Memory: Save Selection to Memory"
      },
      {
        "command": "copilot-memory.search",
        "title": "Copilot Memory: Search Memories"
      },
      {
        "command": "copilot-memory.showAll",
        "title": "Copilot Memory: Show All Memories"
      },
      {
        "command": "copilot-memory.clearAll",
        "title": "Copilot Memory: Clear All Memories"
      }
    ],
    "configuration": {
      "title": "Copilot Memory",
      "properties": {
        "copilotMemory.maxContextItems": {
          "type": "number",
          "default": 5,
          "description": "Maximum number of memories to include in context"
        },
        "copilotMemory.storageDir": {
          "type": "string",
          "default": "",
          "description": "Custom storage directory (default: ~/.copilot-memory)"
        },
        "copilotMemory.debug": {
          "type": "boolean",
          "default": false,
          "description": "Enable debug logging to output channel"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "tsc --noEmit",
    "package": "npx @vscode/vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.96.0",
    "typescript": "^5.5.0"
  }
}
