{
  "name": "copilot-memory",
  "displayName": "Copilot Memory",
  "description": "Persistent local memory for GitHub Copilot Chat across sessions",
  "version": "0.0.1",
  "publisher": "local",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/local/copilot-memory"
  },
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [],
  "contributes": {
    "languageModelTools": [
      {
        "name": "copilot-memory_save",
        "displayName": "Save Memory",
        "description": "Save information to persistent local memory. Use this to remember decisions, solutions, patterns, architecture notes, or anything worth recalling later.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "content": {
              "type": "string",
              "description": "The information to save"
            },
            "scope": {
              "type": "string",
              "enum": [
                "global",
                "project"
              ],
              "description": "global = your notes across all repos, project = scoped to current repo"
            },
            "type": {
              "type": "string",
              "enum": [
                "manual",
                "decision",
                "preference",
                "constraint",
                "bug-root-cause",
                "architecture-note",
                "command-snippet"
              ],
              "description": "Optional memory type to improve retrieval and organization"
            }
          },
          "required": [
            "content"
          ]
        },
        "canBeReferencedInPrompt": true
      },
      {
        "name": "copilot-memory_search",
        "displayName": "Search Memory",
        "description": "Search saved memories for relevant context. Uses FTS5 indexing with optional hybrid vector search. Searches both global and project-scoped memories.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "query": {
              "type": "string",
              "description": "Search query to find relevant memories"
            }
          },
          "required": [
            "query"
          ]
        },
        "canBeReferencedInPrompt": true
      },
      {
        "name": "copilot-memory_list",
        "displayName": "List Memories",
        "description": "List all saved memories, optionally filtered by scope.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "scope": {
              "type": "string",
              "enum": [
                "global",
                "project"
              ],
              "description": "Filter by scope, or omit to list all"
            }
          }
        },
        "canBeReferencedInPrompt": true
      },
      {
        "name": "copilot-memory_delete",
        "displayName": "Delete Memory",
        "description": "Delete a specific memory by its ID.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "description": "The UUID of the memory to delete"
            }
          },
          "required": [
            "id"
          ]
        },
        "canBeReferencedInPrompt": true
      },
      {
        "name": "copilot-memory_refresh",
        "displayName": "Refresh Memory",
        "description": "Force refresh memory state and return current memory version fingerprints.",
        "inputSchema": {
          "type": "object",
          "properties": {}
        },
        "canBeReferencedInPrompt": true
      }
    ],
    "commands": [
      {
        "command": "copilot-memory.saveSelection",
        "title": "Copilot Memory: Save Selection to Memory"
      },
      {
        "command": "copilot-memory.search",
        "title": "Copilot Memory: Search Memories"
      },
      {
        "command": "copilot-memory.showAll",
        "title": "Copilot Memory: Show All Memories"
      },
      {
        "command": "copilot-memory.clearAll",
        "title": "Copilot Memory: Clear All Memories"
      },
      {
        "command": "copilot-memory.refresh",
        "title": "Copilot Memory: Refresh Memory State"
      },
      {
        "command": "copilot-memory.backfillVectors",
        "title": "Copilot Memory: Backfill Embedding Vectors"
      }
    ],
    "configuration": {
      "title": "Copilot Memory",
      "properties": {
        "copilotMemory.maxContextItems": {
          "type": "number",
          "default": 5,
          "description": "Maximum number of memories to include in context"
        },
        "copilotMemory.storageDir": {
          "type": "string",
          "default": "",
          "description": "Custom storage directory (default: ~/.copilot-memory)"
        },
        "copilotMemory.debug": {
          "type": "boolean",
          "default": false,
          "description": "Enable debug logging to output channel"
        },
        "copilotMemory.autoIngestOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Automatically ingest memories when files are saved"
        },
        "copilotMemory.autoIngestStrategy": {
          "type": "string",
          "enum": ["selective", "snapshot"],
          "default": "selective",
          "description": "Ingest strategy: selective stores high-signal insights, snapshot stores raw file snippets"
        },
        "copilotMemory.autoIngestMaxChars": {
          "type": "number",
          "default": 2000,
          "description": "Maximum characters captured per saved file snapshot"
        },
        "copilotMemory.autoIngestMaxInsights": {
          "type": "number",
          "default": 3,
          "description": "Maximum number of high-signal insights captured per saved file"
        },
        "copilotMemory.autoIngestIgnoreGlobs": {
          "type": "array",
          "default": [
            "**/node_modules/**",
            "**/.git/**",
            "**/out/**",
            "**/dist/**",
            "**/*.lock"
          ],
          "items": {
            "type": "string"
          },
          "description": "Glob patterns ignored by auto-ingest"
        },
        "copilotMemory.defaultSaveScope": {
          "type": "string",
          "enum": ["global", "project"],
          "default": "project",
          "description": "Default scope when saving memories (global = cross-repo, project = current repo)"
        },
        "copilotMemory.searchMode": {
          "type": "string",
          "enum": ["sparse", "hybrid-cloud", "auto"],
          "default": "auto",
          "description": "Search retrieval mode. sparse = FTS5 only, hybrid-cloud = FTS5 + cloud embeddings, auto = best available"
        },
        "copilotMemory.embeddingProvider": {
          "type": "string",
          "enum": ["none", "openai"],
          "default": "none",
          "description": "Embedding provider for hybrid search"
        },
        "copilotMemory.embeddingApiKey": {
          "type": "string",
          "default": "",
          "description": "API key for the embedding provider"
        },
        "copilotMemory.embeddingModel": {
          "type": "string",
          "default": "",
          "description": "Embedding model name (e.g., text-embedding-3-small)"
        },
        "copilotMemory.embeddingDimensions": {
          "type": "number",
          "default": 0,
          "description": "Embedding dimensions (0 = provider default)"
        },
        "copilotMemory.embeddingBaseUrl": {
          "type": "string",
          "default": "",
          "description": "Custom base URL for the embedding API"
        }
      }
    }
  },
  "scripts": {
    "check-types": "tsc --noEmit -p ./",
    "compile": "npm run check-types && node esbuild.js",
    "watch": "node esbuild.js --watch",
    "compile-tests": "tsc -p ./ --outDir out",
    "lint": "npm run check-types",
    "test": "npm run compile-tests && node --test out/test/**/*.test.js",
    "package": "npm run check-types && node esbuild.js --production",
    "vscode:prepublish": "npm run package",
    "vsix": "npx @vscode/vsce package --allow-missing-repository",
    "publish:vsce": "npx @vscode/vsce publish"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.96.0",
    "esbuild": "^0.25.2",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0"
  }
}
